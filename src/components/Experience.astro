---
/**
 * Experience — "Turning the Page"
 * Work experiences as book pages with GSAP 3D page-turn animations.
 */

const chapters = [
  {
    chapter: "Chapter I",
    role: "Software Engineer",
    company: "Xbox / Microsoft",
    period: "Present",
    description: "Building the future of gaming experiences. Engineering systems that connect millions of players across the world.",
    highlights: ["Game platform engineering", "Large-scale distributed systems", "Player experience features"],
  },
  {
    chapter: "Chapter II",
    role: "Your Previous Role",
    company: "Previous Company",
    period: "Past",
    description: "A chapter of growth and discovery — laying the foundation for what was to come.",
    highlights: ["Key achievement one", "Key achievement two", "Key achievement three"],
  },
  {
    chapter: "Chapter III",
    role: "Where It All Began",
    company: "First Steps",
    period: "The Beginning",
    description: "Every story has a first page. This is where curiosity met code and a journey was born.",
    highlights: ["Foundational learning", "First projects", "Discovering passion"],
  },
];
---

<section id="experience" class="section relative">
  <div class="max-w-4xl mx-auto w-full">
    <!-- Section header -->
    <div class="text-center mb-12 experience-header">
      <p class="text-lamplight text-sm tracking-[0.3em] uppercase mb-3 neon-text">Experience</p>
      <h2 class="text-4xl md:text-5xl font-serif text-cream">Turning the <span class="text-bright-gold italic neon-text-pink">Page</span></h2>
      <div class="divider mt-4"></div>
    </div>

    <!-- Book -->
    <div class="book-wrapper" id="book-wrapper" style="perspective: 1400px;">
      <!-- Page navigation -->
      <div class="flex justify-center gap-6 mb-6">
        <button id="prev-page" class="text-lavender/40 hover:text-lamplight transition-colors text-sm tracking-widest uppercase cursor-pointer disabled:opacity-20 disabled:cursor-default" disabled>
          ← Previous
        </button>
        <span id="page-counter" class="text-lavender/30 text-sm font-serif italic">page 1 of {chapters.length}</span>
        <button id="next-page" class="text-lavender/40 hover:text-lamplight transition-colors text-sm tracking-widest uppercase cursor-pointer disabled:opacity-20 disabled:cursor-default">
          Next →
        </button>
      </div>

      <!-- Pages stack -->
      <div class="book-pages relative" id="book-pages" style="min-height: 380px;">
        {chapters.map((ch, index) => (
          <div
            class:list={[
              "book-page absolute inset-0 backface-hidden rounded-xl overflow-hidden",
              "border border-cream/10 backdrop-blur-sm",
              index === 0 ? "opacity-100 z-10" : "opacity-0 z-0",
            ]}
            data-page={index}
            style={`transform-style: preserve-3d; ${index > 0 ? 'transform: rotateY(20deg); pointer-events: none;' : ''}`}
          >
            {/* Parchment-like inner background */}
            <div class="absolute inset-0 bg-gradient-to-br from-[#1a1530]/95 via-[#14102a]/90 to-[#0d0f20]/95"></div>

            {/* Gold edge glow */}
            <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-lamplight/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-bright-gold/20 to-transparent"></div>
            <div class="absolute top-0 left-0 w-px h-full bg-gradient-to-b from-transparent via-starlight/25 to-transparent"></div>

            {/* Page corner fold */}
            <div class="absolute top-0 right-0 w-0 h-0 border-t-[40px] border-t-lamplight/[0.07] border-l-[40px] border-l-transparent"></div>

            {/* Content */}
            <div class="relative z-10 p-8 md:p-12">
              <p class="text-lamplight/40 text-xs tracking-[0.4em] uppercase mb-6 font-sans">{ch.chapter}</p>

              <h3 class="text-2xl md:text-3xl font-serif text-cream mb-1">{ch.role}</h3>
              <p class="text-lamplight font-serif italic text-lg mb-1">{ch.company}</p>
              <p class="text-lavender/40 text-sm mb-6">{ch.period}</p>

              <p class="text-lavender/80 leading-relaxed mb-6 max-w-2xl">{ch.description}</p>

              <ul class="space-y-2">
                {ch.highlights.map((h) => (
                  <li class="flex items-start gap-3 text-lavender/60 text-sm">
                    <span class="text-lamplight mt-0.5">✦</span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>

              <p class="absolute bottom-5 right-8 text-lavender/15 text-xs font-serif italic">
                page {index + 1}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- Page dots -->
      <div class="flex justify-center gap-2 mt-6">
        {chapters.map((_, index) => (
          <button
            class:list={[
              "page-dot w-2 h-2 rounded-full transition-all duration-300 cursor-pointer",
              index === 0 ? "bg-lamplight scale-125" : "bg-lavender/20 hover:bg-lavender/40",
            ]}
            data-dot={index}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .backface-hidden {
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let currentPage = 0;
  const pages = document.querySelectorAll<HTMLElement>(".book-page");
  const dots = document.querySelectorAll<HTMLElement>(".page-dot");
  const prevBtn = document.getElementById("prev-page") as HTMLButtonElement;
  const nextBtn = document.getElementById("next-page") as HTMLButtonElement;
  const counter = document.getElementById("page-counter")!;
  const totalPages = pages.length;
  let isAnimating = false;

  function goToPage(target: number) {
    if (target === currentPage || target < 0 || target >= totalPages || isAnimating) return;
    isAnimating = true;

    const direction = target > currentPage ? 1 : -1;
    const outPage = pages[currentPage];
    const inPage = pages[target];

    // Animate out current page (flip away)
    gsap.to(outPage, {
      rotateY: direction * -90,
      opacity: 0,
      scale: 0.95,
      duration: 0.6,
      ease: "power2.in",
      onComplete: () => {
        outPage.style.zIndex = "0";
        outPage.style.pointerEvents = "none";
      },
    });

    // Prepare incoming page
    gsap.set(inPage, {
      rotateY: direction * 20,
      opacity: 0,
      scale: 0.95,
      zIndex: 10,
      pointerEvents: "auto",
    });

    // Animate in new page (flip in)
    gsap.to(inPage, {
      rotateY: 0,
      opacity: 1,
      scale: 1,
      duration: 0.6,
      delay: 0.15,
      ease: "power2.out",
      onComplete: () => {
        isAnimating = false;
      },
    });

    // Update state
    currentPage = target;
    updateControls();
  }

  function updateControls() {
    prevBtn.disabled = currentPage === 0;
    nextBtn.disabled = currentPage === totalPages - 1;
    counter.textContent = `page ${currentPage + 1} of ${totalPages}`;

    dots.forEach((dot, i) => {
      if (i === currentPage) {
        dot.classList.add("bg-lamplight", "scale-125");
        dot.classList.remove("bg-lavender/20");
      } else {
        dot.classList.remove("bg-lamplight", "scale-125");
        dot.classList.add("bg-lavender/20");
      }
    });
  }

  prevBtn.addEventListener("click", () => goToPage(currentPage - 1));
  nextBtn.addEventListener("click", () => goToPage(currentPage + 1));
  dots.forEach((dot, i) => dot.addEventListener("click", () => goToPage(i)));

  // Keyboard navigation
  document.addEventListener("keydown", (e) => {
    const bookRect = document.getElementById("book-wrapper")!.getBoundingClientRect();
    const inView = bookRect.top < window.innerHeight && bookRect.bottom > 0;
    if (!inView) return;

    if (e.key === "ArrowLeft") goToPage(currentPage - 1);
    if (e.key === "ArrowRight") goToPage(currentPage + 1);
  });

  // Scroll-triggered entrance
  gsap.from(".experience-header", {
    scrollTrigger: {
      trigger: "#experience",
      start: "top 70%",
      toggleActions: "play none none reverse",
    },
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power3.out",
  });

  gsap.from("#book-wrapper", {
    scrollTrigger: {
      trigger: "#book-wrapper",
      start: "top 80%",
      toggleActions: "play none none reverse",
    },
    y: 50,
    opacity: 0,
    duration: 0.9,
    ease: "power3.out",
  });
</script>

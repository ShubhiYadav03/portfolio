---
/**
 * Experience — "Turning the Page"
 * Real 3D page-flip book using StPageFlip library.
 */

const chapters = [
  {
    chapter: "Chapter I",
    role: "Software Engineer",
    company: "Xbox / Microsoft",
    period: "Present",
    description: "Building the future of gaming experiences. Engineering systems that connect millions of players across the world.",
    highlights: ["Game platform engineering", "Large-scale distributed systems", "Player experience features"],
  },
  {
    chapter: "Chapter II",
    role: "Your Previous Role",
    company: "Previous Company",
    period: "Past",
    description: "A chapter of growth and discovery — laying the foundation for what was to come.",
    highlights: ["Key achievement one", "Key achievement two", "Key achievement three"],
  },
  {
    chapter: "Chapter III",
    role: "Where It All Began",
    company: "First Steps",
    period: "The Beginning",
    description: "Every story has a first page. This is where curiosity met code and a journey was born.",
    highlights: ["Foundational learning", "First projects", "Discovering passion"],
  },
];
---

<section id="experience" class="section relative">
  <div class="max-w-4xl mx-auto w-full">
    <!-- Section header -->
    <div class="text-center mb-12 experience-header">
      <p class="text-lamplight text-sm tracking-[0.3em] uppercase mb-3">Experience</p>
      <h2 class="text-4xl md:text-5xl font-serif text-cream">Turning the <span class="text-bright-gold italic">Page</span></h2>
      <p class="text-lavender/40 text-sm mt-2 italic">Click the page edges or use the arrows to flip</p>
      <div class="divider mt-4"></div>
    </div>

    <!-- Flipbook container -->
    <div class="flex justify-center">
      <div id="flipbook" class="flipbook-container"></div>
    </div>

    <!-- Navigation arrows -->
    <div class="flex justify-center gap-8 mt-6">
      <button id="prev-page" class="text-lavender/40 hover:text-lamplight transition-colors text-2xl cursor-pointer px-4 py-2">
        ‹
      </button>
      <span id="page-counter" class="text-lavender/30 text-sm font-serif italic self-center"></span>
      <button id="next-page" class="text-lavender/40 hover:text-lamplight transition-colors text-2xl cursor-pointer px-4 py-2">
        ›
      </button>
    </div>

    <!-- Hidden page templates for StPageFlip -->
    <div id="page-templates" class="hidden">
      <!-- Cover -->
      <div class="page page-cover" data-density="hard">
        <div class="page-inner cover-front">
          <!-- Corner flourishes -->
          <span class="cover-ornament" style="top:20px;left:20px;">❧</span>
          <span class="cover-ornament" style="top:20px;right:20px;transform:scaleX(-1);">❧</span>
          <span class="cover-ornament" style="bottom:20px;left:20px;transform:scaleY(-1);">❧</span>
          <span class="cover-ornament" style="bottom:20px;right:20px;transform:scale(-1);">❧</span>

          <div class="flex flex-col items-center justify-center h-full gap-3 p-8 text-center">
            <div class="w-16 h-px bg-gradient-to-r from-transparent via-[#b48c3c]/40 to-transparent mb-1"></div>
            <p style="color:#a08050;font-size:10px;letter-spacing:0.3em;" class="uppercase font-sans">The Chronicles of</p>
            <h3 class="text-2xl font-serif" style="color:#d4b060;">Shubhi Yadav</h3>
            <div class="w-10 h-px bg-gradient-to-r from-transparent via-[#b48c3c]/30 to-transparent"></div>
            <p class="font-serif italic text-sm" style="color:#8a7040;">The Story So Far</p>
            <div class="w-16 h-px bg-gradient-to-r from-transparent via-[#b48c3c]/40 to-transparent mt-1"></div>
          </div>
        </div>
      </div>

      <!-- Chapter pages -->
      {chapters.map((ch, index) => (
        <div class="page" data-density="soft">
          <div class="page-inner">
            <p class="page-chapter text-[10px] tracking-[0.3em] uppercase mb-1 font-sans">{ch.chapter}</p>
            <div class="chapter-ornament"></div>
            <h3 class="page-title text-lg font-serif mb-0.5 leading-snug mt-3">{ch.role}</h3>
            <p class="page-company font-serif italic text-sm mb-0.5">{ch.company}</p>
            <p class="page-period text-[11px] mb-4">{ch.period}</p>
            <p class="page-text text-xs leading-relaxed mb-4">{ch.description}</p>
            <ul class="space-y-1.5">
              {ch.highlights.map((h) => (
                <li class="flex items-start gap-2 page-highlight text-xs">
                  <span class="page-accent text-[10px] mt-0.5">✦</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
            <p class="absolute bottom-3 right-4 page-number text-[10px] font-serif italic">
              — {index + 1} —
            </p>
          </div>
        </div>
      ))}

      <!-- Back cover -->
      <div class="page page-cover" data-density="hard">
        <div class="page-inner cover-back">
          <span class="cover-ornament" style="top:20px;left:20px;">❧</span>
          <span class="cover-ornament" style="top:20px;right:20px;transform:scaleX(-1);">❧</span>
          <span class="cover-ornament" style="bottom:20px;left:20px;transform:scaleY(-1);">❧</span>
          <span class="cover-ornament" style="bottom:20px;right:20px;transform:scale(-1);">❧</span>

          <div class="flex flex-col items-center justify-center h-full gap-3 p-8 text-center">
            <p class="font-serif italic text-sm" style="color:#8a7040;">To be continued...</p>
            <div class="w-8 h-px bg-[#b48c3c]/20"></div>
            <p style="color:#6a5430;" class="text-xs">❦</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .flipbook-container {
    position: relative;
  }

  .hidden {
    display: none !important;
  }

  /* ── Inner pages: aged parchment ── */
  .page {
    background: linear-gradient(145deg, #e8dcc8 0%, #d9c9a8 30%, #e2d4b8 60%, #d5c49e 100%);
    overflow: hidden;
    position: relative;
    border-radius: 2px;
  }

  /* Foxing stains and aging marks */
  .page::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 15% 85%, rgba(139, 105, 60, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(120, 90, 50, 0.08) 0%, transparent 40%),
      radial-gradient(circle at 50% 50%, rgba(160, 130, 80, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Subtle worn page edge */
  .page::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg,
      rgba(180, 160, 120, 0.3),
      rgba(160, 140, 100, 0.5) 30%,
      rgba(140, 120, 80, 0.4) 70%,
      rgba(180, 160, 120, 0.3)
    );
    pointer-events: none;
  }

  .page-inner {
    position: relative;
    width: 100%;
    height: 100%;
    padding: 1.75rem 1.5rem;
    box-sizing: border-box;
  }

  /* Spine shadow on inner pages */
  .page-inner::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 20px;
    height: 100%;
    background: linear-gradient(90deg, rgba(100, 70, 30, 0.12), transparent);
    pointer-events: none;
  }

  /* ── Covers: aged dark leather ── */
  .page-cover {
    background: linear-gradient(145deg, #2a1f14 0%, #1e1508 40%, #241a0e 70%, #1a1208 100%);
    border: none;
    border-radius: 3px;
  }

  .page-cover::before {
    background:
      radial-gradient(ellipse at 50% 50%, rgba(180, 140, 60, 0.03) 0%, transparent 70%);
  }

  .page-cover::after {
    display: none;
  }

  .cover-front, .cover-back {
    height: 100%;
    border-radius: 2px;
    position: relative;
  }

  /* Ornamental border on cover — aged gold */
  .cover-front::before, .cover-back::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(180, 140, 60, 0.25);
    border-radius: 1px;
    pointer-events: none;
  }

  /* Double border */
  .cover-front::after, .cover-back::after {
    content: '';
    position: absolute;
    inset: 16px;
    border: 1px solid rgba(180, 140, 60, 0.12);
    border-radius: 1px;
    pointer-events: none;
  }

  /* Corner flourishes on cover */
  .cover-ornament {
    position: absolute;
    width: 24px;
    height: 24px;
    opacity: 0.3;
    color: #b48c3c;
    font-size: 18px;
    line-height: 1;
  }

  /* Leather texture feel via subtle noise */
  .cover-front {
    box-shadow:
      inset 0 0 40px rgba(0, 0, 0, 0.4),
      inset 0 0 80px rgba(30, 20, 5, 0.3);
  }

  .cover-back {
    box-shadow:
      inset 0 0 40px rgba(0, 0, 0, 0.5),
      inset 0 0 60px rgba(30, 20, 5, 0.3);
  }

  /* Book drop shadow — warm and deep */
  :global(.stf__parent) {
    filter: drop-shadow(0 12px 40px rgba(20, 10, 0, 0.4))
            drop-shadow(0 4px 12px rgba(40, 25, 5, 0.3));
  }

  /* ── Text colors for parchment pages ── */
  .page-chapter { color: #6b5430; }
  .page-title { color: #2a1f14; }
  .page-company { color: #7a5c2e; }
  .page-period { color: #9a8a6c; }
  .page-text { color: #4a3d2a; }
  .page-highlight { color: #5a4830; }
  .page-accent { color: #8b6914; }
  .page-number { color: #c4b08a; }

  /* Decorative chapter ornament */
  .chapter-ornament {
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #a08050, transparent);
    margin: 0.5rem 0;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { PageFlip } from "page-flip";

  gsap.registerPlugin(ScrollTrigger);

  const container = document.getElementById("flipbook")!;
  const templates = document.getElementById("page-templates")!;
  const prevBtn = document.getElementById("prev-page")!;
  const nextBtn = document.getElementById("next-page")!;
  const counter = document.getElementById("page-counter")!;

  // Determine book size based on viewport
  const isMobile = window.innerWidth < 640;
  const bookWidth = isMobile ? Math.min(window.innerWidth - 48, 300) : 360;
  const bookHeight = Math.round(bookWidth * 1.35);

  const pageFlip = new PageFlip(container, {
    width: bookWidth,
    height: bookHeight,
    size: "fixed",
    showCover: true,
    maxShadowOpacity: 0.6,
    mobileScrollSupport: false,
    useMouseEvents: true,
    flippingTime: 800,
    startPage: 0,
    drawShadow: true,
    autoSize: false,
    startZIndex: 0,
    usePortrait: isMobile,
    swipeDistance: 30,
  });

  // Load pages from hidden templates
  const pageElements = templates.querySelectorAll(".page");
  pageFlip.loadFromHTML(pageElements);

  function updateCounter() {
    const current = pageFlip.getCurrentPageIndex();
    const total = pageFlip.getPageCount();
    counter.textContent = `${current + 1} / ${total}`;
  }

  pageFlip.on("flip", () => updateCounter());
  updateCounter();

  prevBtn.addEventListener("click", () => pageFlip.flipPrev());
  nextBtn.addEventListener("click", () => pageFlip.flipNext());

  // Keyboard
  document.addEventListener("keydown", (e) => {
    const rect = container.getBoundingClientRect();
    const inView = rect.top < window.innerHeight && rect.bottom > 0;
    if (!inView) return;
    if (e.key === "ArrowLeft") pageFlip.flipPrev();
    if (e.key === "ArrowRight") pageFlip.flipNext();
  });

  // Scroll entrance
  gsap.from(".experience-header", {
    scrollTrigger: { trigger: "#experience", start: "top 70%", toggleActions: "play none none reverse" },
    y: 40, opacity: 0, duration: 0.8, ease: "power3.out",
  });

  gsap.from("#flipbook", {
    scrollTrigger: { trigger: "#flipbook", start: "top 85%", toggleActions: "play none none reverse" },
    y: 50, opacity: 0, duration: 0.9, ease: "power3.out",
  });
</script>

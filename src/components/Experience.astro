---
/**
 * Experience — "Turning the Page"
 * Work experiences as book pages with GSAP page-turn animations.
 */

const chapters = [
  {
    chapter: "Chapter I",
    role: "Software Engineer",
    company: "Xbox / Microsoft",
    period: "Present",
    description: "Building the future of gaming experiences. Engineering systems that connect millions of players across the world.",
    highlights: ["Game platform engineering", "Large-scale distributed systems", "Player experience features"],
  },
  {
    chapter: "Chapter II",
    role: "Your Previous Role",
    company: "Previous Company",
    period: "Past",
    description: "A chapter of growth and discovery — laying the foundation for what was to come.",
    highlights: ["Key achievement one", "Key achievement two", "Key achievement three"],
  },
];
---

<section id="experience" class="section relative">
  <div class="max-w-4xl mx-auto w-full">
    <!-- Section header -->
    <div class="text-center mb-16 experience-header">
      <p class="text-lamplight text-sm tracking-[0.3em] uppercase mb-3">Experience</p>
      <h2 class="text-4xl md:text-5xl font-serif text-cream">Turning the <span class="text-lamplight italic">Page</span></h2>
      <div class="divider mt-4"></div>
    </div>

    <!-- Book container -->
    <div class="book-container relative perspective-[1200px]" id="book">
      {chapters.map((ch, index) => (
        <div
          class:list={[
            "book-page relative bg-gradient-to-br from-[#1a1530]/90 to-[#0d0f20]/90",
            "border border-cream/10 rounded-lg p-8 md:p-12 backdrop-blur-sm",
            "transition-all duration-700",
            index > 0 ? "mt-8" : "",
          ]}
          data-page={index}
        >
          {/* Page corner decoration */}
          <div class="absolute top-0 right-0 w-16 h-16 overflow-hidden">
            <div class="absolute top-0 right-0 w-px h-16 bg-gradient-to-b from-lamplight/30 to-transparent"></div>
            <div class="absolute top-0 right-0 h-px w-16 bg-gradient-to-l from-lamplight/30 to-transparent"></div>
          </div>

          {/* Chapter marker */}
          <p class="text-lamplight/50 text-xs tracking-[0.4em] uppercase mb-6 font-sans">{ch.chapter}</p>

          {/* Content */}
          <h3 class="text-2xl md:text-3xl font-serif text-cream mb-1">{ch.role}</h3>
          <p class="text-lamplight font-serif italic text-lg mb-1">{ch.company}</p>
          <p class="text-lavender/40 text-sm mb-6">{ch.period}</p>

          <p class="text-lavender/80 leading-relaxed mb-6 max-w-2xl">{ch.description}</p>

          <ul class="space-y-2">
            {ch.highlights.map((h) => (
              <li class="flex items-start gap-3 text-lavender/60 text-sm">
                <span class="text-lamplight mt-1">✦</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>

          {/* Page number */}
          <p class="absolute bottom-4 right-6 text-lavender/20 text-xs font-serif italic">
            page {index + 1}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Header reveal
  gsap.from(".experience-header", {
    scrollTrigger: {
      trigger: "#experience",
      start: "top 70%",
      toggleActions: "play none none reverse",
    },
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power3.out",
  });

  // Page reveals with stagger
  gsap.from(".book-page", {
    scrollTrigger: {
      trigger: "#book",
      start: "top 75%",
      toggleActions: "play none none reverse",
    },
    y: 60,
    opacity: 0,
    rotateX: -8,
      transformOrigin: "top center",
      duration: 0.9,
      stagger: 0.25,
      ease: "power3.out",
    });
</script>

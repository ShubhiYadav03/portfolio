---
/**
 * About — "A Little World Made Cunningly"
 * Interactive 3D globe with glowing hotspots for life facets.
 */

const facets = [
  { emoji: "🎮", title: "Gaming", description: "Building experiences at Xbox — where play meets engineering." },
  { emoji: "📚", title: "Reading", description: "Devouring worlds one page at a time. Metaphors are my native tongue." },
  { emoji: "💻", title: "Engineering", description: "Crafting software with care — from low-level systems to interactive frontends." },
  { emoji: "🎵", title: "Music", description: "Piano keys and ambient soundscapes. Code and composition share the same rhythm." },
];
---

<section id="about" class="section relative">
  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Globe container (Three.js renders here) -->
    <div class="relative flex items-center justify-center min-h-[400px]" id="globe-container">
      <canvas id="globe-canvas" class="w-full h-full max-w-[400px] max-h-[400px] aspect-square"></canvas>
      <!-- Fallback glow ring when WebGL isn't loaded yet -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-64 h-64 rounded-full border border-lamplight/20 animate-pulse"></div>
      </div>
    </div>

    <!-- Text content -->
    <div class="flex flex-col gap-8">
      <div class="about-header">
        <p class="text-lamplight text-sm tracking-[0.3em] uppercase mb-3">About</p>
        <h2 class="text-4xl md:text-5xl font-serif text-cream leading-tight">
          A Little World<br />Made <span class="text-lamplight italic">Cunningly</span>
        </h2>
        <p class="text-lavender/60 text-sm mt-2 italic font-serif">— John Donne</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="facets-grid">
        {facets.map((facet) => (
          <div class="facet-card group p-4 rounded-xl border border-cream/5 bg-cream/[0.02] hover:border-lamplight/30 hover:bg-lamplight/[0.04] transition-all duration-300 cursor-default">
            <span class="text-2xl mb-2 block">{facet.emoji}</span>
            <h3 class="text-cream font-serif text-lg mb-1">{facet.title}</h3>
            <p class="text-lavender/60 text-sm leading-relaxed">{facet.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Animate heading
  gsap.from(".about-header", {
    scrollTrigger: {
      trigger: "#about",
      start: "top 70%",
      toggleActions: "play none none reverse",
    },
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power3.out",
  });

  // Animate facet cards
  gsap.from(".facet-card", {
    scrollTrigger: {
      trigger: "#facets-grid",
      start: "top 80%",
      toggleActions: "play none none reverse",
    },
    y: 30,
    opacity: 0,
    duration: 0.6,
    stagger: 0.12,
    ease: "power2.out",
  });
</script>
